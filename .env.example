# LLM provider: openrouter | openai | groq
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=Python Q&A Assistant

# Optional: OpenAI or Groq instead of OpenRouter
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile

# Pinecone (https://app.pinecone.io/)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=python-qa-assistant
PINECONE_NAMESPACE=default
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Embedding provider: auto | openai | huggingface | hash
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Retrieval settings
TOP_K=5
DATA_PATH=./data/sample_python_qa.json

# API settings
API_HOST=0.0.0.0
API_PORT=8000
